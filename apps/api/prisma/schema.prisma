generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id                  String   @id @default(uuid())
  shopDomain          String   @unique
  shopifyShopId       BigInt   @unique
  accessToken         String // encrypted at application layer
  planTier            String   @default("free") // free, growth, scale, enterprise
  aiTone              String   @default("friendly_professional")
  escalationThreshold Float    @default(0.7)
  aiRules             Json?    @map("ai_rules")
  widgetConfig         Json?     @map("widget_config")
  isActive             Boolean   @default(true)
  subscriptionId       String?   @map("subscription_id")
  subscriptionStatus   String?   @map("subscription_status")
  trialEndsAt          DateTime? @map("trial_ends_at")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  gracePeriodEndsAt    DateTime? @map("grace_period_ends_at")
  cancelledAt          DateTime? @map("cancelled_at")
  usageLineItemId      String?   @map("usage_line_item_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  conversations         Conversation[]
  orders                Order[]
  knowledgeBase         KnowledgeBase[]
  agents                Agent[]
  revenueAttributions   RevenueAttribution[]
  analyticsDailySummaries AnalyticsDailySummary[]

  @@map("merchants")
}

model Conversation {
  id                String    @id @default(uuid())
  merchantId        String    @map("merchant_id")
  customerEmail     String?   @map("customer_email")
  customerShopifyId BigInt?   @map("customer_shopify_id")
  channel           String // widget, shopify_inbox, sms, whatsapp, email, instagram
  status            String    @default("active") // active, resolved, escalated, closed
  aiResolution      Boolean   @default(false) @map("ai_resolution")
  usageCounted      Boolean   @default(false) @map("usage_counted")
  aiPaused          Boolean   @default(false) @map("ai_paused")
  escalatedTo       String?   @map("escalated_to")
  assignedAgentId   String?   @map("assigned_agent_id")
  priority          Int       @default(0)
  escalationContext Json?     @map("escalation_context")
  queuedAt          DateTime? @map("queued_at")
  slaDueAt          DateTime? @map("sla_due_at")
  sentimentScore    Float?    @map("sentiment_score")
  revenueImpact     Decimal?  @map("revenue_impact") @db.Decimal(12, 2)
  endedAt           DateTime? @map("ended_at")
  cartProductIds    String[]  @default([]) @map("cart_product_ids")
  cartValueAtStart  Decimal?  @map("cart_value_at_start") @db.Decimal(12, 2)
  visitorId         String?   @map("visitor_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  merchant            Merchant             @relation(fields: [merchantId], references: [id])
  messages            Message[]
  events              Event[]
  revenueAttributions RevenueAttribution[]

  @@index([merchantId, status])
  @@index([merchantId, assignedAgentId])
  @@index([merchantId, priority])
  @@index([customerEmail])
  @@index([visitorId])
  @@index([createdAt])
  @@index([endedAt])
  @@map("conversations")
}


model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderType     String   @map("sender_type") // ai, customer, human, system
  senderId       String?  @map("sender_id")
  content        String
  aiConfidence   Float?   @map("ai_confidence")
  aiIntent       String?  @map("ai_intent")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Order {
  id                String    @id @default(uuid())
  merchantId        String    @map("merchant_id")
  shopifyOrderId    BigInt    @unique @map("shopify_order_id")
  customerEmail     String?   @map("customer_email")
  totalPrice        Decimal?  @map("total_price") @db.Decimal(12, 2)
  productIds        String[]  @default([]) @map("product_ids")
  fulfillmentStatus String?   @map("fulfillment_status")
  trackingNumbers   String[]  @map("tracking_numbers")
  carrier           String?
  trackingStatus    String?   @map("tracking_status")
  estimatedDelivery DateTime? @map("estimated_delivery")
  trackingHistory   Json?     @map("tracking_history")
  lastTrackedAt     DateTime? @map("last_tracked_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  merchant            Merchant             @relation(fields: [merchantId], references: [id])
  revenueAttributions RevenueAttribution[]

  @@index([merchantId, customerEmail])
  @@index([merchantId, createdAt])
  @@index([shopifyOrderId])
  @@map("orders")
}

model RevenueAttribution {
  id              String   @id @default(uuid())
  merchantId      String   @map("merchant_id")
  conversationId  String   @map("conversation_id")
  orderId         String?  @map("order_id")
  shopifyOrderId  BigInt?  @map("shopify_order_id")
  attributionType String   @map("attribution_type") // direct | influence
  revenueType     String   @map("revenue_type") // recovered_cart | saved_order | upsell | purchase
  amount          Decimal  @db.Decimal(12, 2)
  properties      Json?
  attributedAt    DateTime @default(now()) @map("attributed_at")

  merchant     Merchant     @relation(fields: [merchantId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  order        Order?       @relation(fields: [orderId], references: [id])

  @@unique([conversationId, orderId, revenueType])
  @@index([merchantId, attributedAt])
  @@index([conversationId])
  @@map("revenue_attributions")
}

model AnalyticsDailySummary {
  id                   String   @id @default(uuid())
  merchantId           String   @map("merchant_id")
  date                 DateTime @db.Date
  conversationsStarted Int      @default(0) @map("conversations_started")
  aiResponses          Int      @default(0) @map("ai_responses")
  humanEscalations     Int      @default(0) @map("human_escalations")
  aiResolutions        Int      @default(0) @map("ai_resolutions")
  cartRecovered        Int      @default(0) @map("cart_recovered")
  ordersPlaced         Int      @default(0) @map("orders_placed")
  widgetOpened         Int      @default(0) @map("widget_opened")
  proactiveTriggered   Int      @default(0) @map("proactive_triggered")
  recoveredCartValue   Decimal  @default(0) @map("recovered_cart_value") @db.Decimal(12, 2)
  savedOrderValue      Decimal  @default(0) @map("saved_order_value") @db.Decimal(12, 2)
  upsellValue          Decimal  @default(0) @map("upsell_value") @db.Decimal(12, 2)
  directRevenue        Decimal  @default(0) @map("direct_revenue") @db.Decimal(12, 2)
  influenceRevenue     Decimal  @default(0) @map("influence_revenue") @db.Decimal(12, 2)
  controlVisitors      Int      @default(0) @map("control_visitors")
  treatmentVisitors    Int      @default(0) @map("treatment_visitors")
  controlConversions   Int      @default(0) @map("control_conversions")
  treatmentConversions Int      @default(0) @map("treatment_conversions")
  avgResponseMs        Float?   @map("avg_response_ms")
  csatScore            Float?   @map("csat_score")
  resolutionRate       Float?   @map("resolution_rate")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, date])
  @@index([merchantId, date])
  @@map("analytics_daily_summaries")
}


model KnowledgeBase {
  id          String                       @id @default(uuid())
  merchantId  String                       @map("merchant_id")
  contentType String                       @map("content_type") // faq, policy, product, shipping
  title       String
  content     String
  embedding   Unsupported("vector(3072)")?
  metadata    Json?
  createdAt   DateTime                     @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId, contentType])
  @@map("knowledge_base")
}

model Event {
  id             String   @id @default(uuid())
  merchantId     String   @map("merchant_id")
  eventType      String   @map("event_type")
  conversationId String?  @map("conversation_id")
  properties     Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@index([merchantId, eventType, createdAt])
  @@index([createdAt])
  @@map("events")
}

model Agent {
  id           String   @id @default(uuid())
  merchantId   String   @map("merchant_id")
  email        String
  name         String
  role         String   @default("agent") // owner, admin, agent, viewer
  avatar       String?
  isOnline     Boolean  @default(false) @map("is_online")
  workingHours Json?    @map("working_hours")
  createdAt    DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, email])
  @@map("agents")
}

model WebhookDelivery {
  id          String   @id // X-Shopify-Webhook-Id
  topic       String
  shopDomain  String   @map("shop_domain")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([shopDomain, topic])
  @@map("webhook_deliveries")
}

