{
  "name": "@nova/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx watch --env-file=.env --clear-screen=false src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --env-file=.env src/lib/encryption.test.ts && tsx --env-file=.env src/lib/security.test.ts && tsx --env-file=.env src/lib/redis.test.ts && tsx --env-file=.env src/middleware/middleware.test.ts && tsx --env-file=.env src/lib/pinecone.test.ts && tsx --env-file=.env src/lib/observability.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@nova/shared": "workspace:*",
    "@pinecone-database/pinecone": "^4.0.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.34.0",
    "bcrypt": "^5.1.1",
    "dd-trace": "^5.22.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "langsmith": "^0.2.0",
    "openai": "^4.67.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.16.5",
    "prisma": "^5.22.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
