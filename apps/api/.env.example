NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://user:pass@localhost:5432/nova_support
# Local: redis://localhost:6379 — Upstash: rediss://default:TOKEN@HOST:6379
REDIS_URL=redis://localhost:6379
# Optional ClickHouse (events also batch to PostgreSQL)
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
LOG_LEVEL=info
ENCRYPTION_KEY=nova_support_dev_encryption_key1
PINECONE_API_KEY=
PINECONE_INDEX_NAME=nova-support-kb
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DATADOG_API_KEY=
DATADOG_APP_KEY=
SENTRY_DSN=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nova-support-production
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Use test charges outside production (default when NODE_ENV !== production)
SHOPIFY_BILLING_TEST=true
SHOPIFY_SCOPES=read_products,read_orders,write_orders,read_customers,read_content,read_shipping,read_checkouts,read_fulfillments
APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
# Carrier APIs (optional — scrape fallback used when unset)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
USPS_USER_ID=
DHL_API_KEY=
CANADA_POST_API_KEY=
ROYAL_MAIL_API_KEY=
AUSTRALIA_POST_API_KEY=
ONTRAC_API_KEY=
AMAZON_TRACKING_API_KEY=
EVRI_API_KEY=
DPD_API_KEY=
PUROLATOR_API_KEY=


